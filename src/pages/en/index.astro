---
import '../../styles/site.css';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://onigirito.github.io/ShadowHarness/';
const pageUrl = `${siteUrl}en/`;
const title = 'Shadow — The AI environment that never forgets';
const description =
  'Shadow is a desktop shell + persistent context layer for Claude Code. The session may end — the context never does.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/png" href={`${base}shadow-icon.png`} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={pageUrl} />
		<link rel="alternate" hreflang="ja" href={siteUrl} />
		<link rel="alternate" hreflang="en" href={pageUrl} />
		<link rel="alternate" hreflang="x-default" href={siteUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={`${siteUrl}og-image.png`} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@ShadowHarness" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}og-image.png`} />

		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'SoftwareApplication',
				name: 'Shadow',
				applicationCategory: 'DeveloperApplication',
				operatingSystem: 'Windows',
				description,
				url: pageUrl,
				image: `${siteUrl}og-image.png`,
				author: { '@type': 'Person', name: 'onigirito' },
			})}
		/>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={`${base}en/`}>SHADOW</a>
			<nav>
				<a href="#concept">Concept</a>
				<a href="#demo">Demo</a>
				<a href="#tech">Under the hood</a>
			</nav>
			<span class="header-links">
				<a class="lang-link" href={base}>日本語</a>
				<a class="x-link" href="https://x.com/ShadowHarness" target="_blank" rel="noopener">
					𝕏 @ShadowHarness
				</a>
			</span>
		</header>

		<main>
			<section class="hero">
				<div class="ring" aria-hidden="true"></div>
				<h1 class="wordmark">SHADOW</h1>
				<p class="tagline">The AI environment that <span class="ac">never forgets</span>.</p>
				<p class="sub">Persistent memory for AI coding agents.</p>
				<div class="cta-row">
					<a class="cta primary" href="https://github.com/onigirito/ShadowHarness" target="_blank" rel="noopener">
						View on GitHub
					</a>
					<a class="cta ghost" href="https://x.com/ShadowHarness" target="_blank" rel="noopener">
						Follow on X
					</a>
				</div>
			</section>

			<section id="concept" class="section">
				<h2>The session may end. The context doesn't.</h2>
				<p class="lead">
					Claude Code does have resume — but resume drags the whole bloated context forward.
					It doesn't distill the essentials and let you continue fresh. Shadow is the
					<strong>receptacle</strong> that catches your context before it's lost: it hosts the
					real Claude Code while quietly building up session lineage, frozen handoff notes,
					and per-topic memory behind the scenes.
				</p>
				<div class="grid-3">
					<div class="card">
						<h3>Memory that persists</h3>
						<p>
							Context and topic notes carry over across sessions automatically. Reset the
							session — pick up right where you left off.
						</p>
					</div>
					<div class="card">
						<h3>The real Claude Code</h3>
						<p>
							No headless wrapper, no watered-down clone. Shadow hosts the actual interactive
							<code>claude</code> CLI, so nothing is lost in translation.
						</p>
					</div>
					<div class="card">
						<h3>One desktop, everything</h3>
						<p>
							Explorer, preview, and the center pane — plus as many CLI panes as you want
							(stack ten if you like). A built-in editor too. No more window juggling.
						</p>
					</div>
				</div>
			</section>

			<section id="demo" class="section alt">
				<h2>See it in action</h2>
				<p class="lead">
					Explorer, the center Claude Code pane, and any number of CLI panes in a single
					window. Panes float freely — add or remove them at will.
				</p>
				<div class="demo-shot">
					<img
						src={`${base}demo-screenshot-1.png`}
						alt="Screenshot of the Shadow desktop app — explorer, the center Claude Code pane, and an agent pane side by side"
						loading="lazy"
						width="1568"
						height="830"
					/>
				</div>

				<div class="demo-shot">
					<video controls playsinline preload="none" poster={`${base}demo-poster.jpg`} width="878" height="830">
						<source src={`${base}demo-editor-highlight.mp4`} type="video/mp4" />
					</video>
					<p class="video-caption">
						32-second PREVIEW pane demo (Japanese narration) — document view, image preview,
						editing with AI code completion, and instant rendering
					</p>
				</div>

				<div class="video-grid">
					<div class="video-card">
						<div class="video-embed">
							<iframe
								src="https://www.youtube-nocookie.com/embed/z0D8-rqVunc"
								title="Shadow — The AI environment that never forgets"
								loading="lazy"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
								allowfullscreen
							></iframe>
						</div>
						<p class="video-caption">Memory — context that survives across sessions</p>
					</div>
					<div class="video-card">
						<div class="video-embed">
							<iframe
								src="https://www.youtube-nocookie.com/embed/h-wGvXwAU6g"
								title="Shadow — The AI workspace that never scatters"
								loading="lazy"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
								allowfullscreen
							></iframe>
						</div>
						<p class="video-caption">Workspace — everything organized under one model</p>
					</div>
				</div>
			</section>

			<section id="tech" class="section">
				<h2>Architecture</h2>
				<p class="lead">
					Shadow is two layers: <code>harness/</code> is the persistent context service (L2),
					and <code>desktop/</code> is the shell you actually work in (L4).
				</p>
				<div class="grid-2">
					<div class="card">
						<h3>L2 — Context Services</h3>
						<p>
							<code>sessions</code> (lineage / whoami), <code>handoff</code> (frozen handoffs),
							<code>distill</code> (topic notes), and <code>notes</code> (recall). They spin up
							on every center spawn, treating the session transcript as the single source of
							truth.
						</p>
					</div>
					<div class="card">
						<h3>L4 — Desktop Shell</h3>
						<p>
							Tauri v2 + ConPTY (portable-pty) + xterm.js. The real <code>claude</code> runs
							in a Windows ConPTY with its bytes piped straight to xterm.js. Panes are managed
							as floating windows — CLI panes (Grok, Codex, Gemini, …) are unlimited.
						</p>
					</div>
				</div>
				<p class="repo-link">
					<a href="https://github.com/onigirito/ShadowHarness" target="_blank" rel="noopener">
						→ Browse the source on GitHub
					</a>
				</p>
			</section>
		</main>

		<footer class="site-footer">
			<span>© 2026 Shadow Harness</span>
			<a href="https://x.com/ShadowHarness" target="_blank" rel="noopener">X</a>
			<a href="https://github.com/onigirito/ShadowHarness" target="_blank" rel="noopener">GitHub</a>
		</footer>
	</body>
</html>
